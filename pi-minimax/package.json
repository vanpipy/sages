      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "bun-types": "^1.3.14",
    "typebox": "^1.1.34",
    "typescript": "^5.4.0"
  },
  "author": "leroy",
  "homepage": "https://codeup.aliyun.com"
}
