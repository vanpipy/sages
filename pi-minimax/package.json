{
  "name": "@sages/pi-minimax",
  "version": "0.1.0",
  "description": "MiniMax AI Platform CLI wrapper for pi - thin shell-out to globally-installed mmx-cli (stateless, no daemon)",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test test/*.test.ts"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "minimax",
    "mmx"
  ],
  "license": "MIT",
  "pi": {
