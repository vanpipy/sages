{
  "name": "@sages/pi-serena",
  "version": "0.1.0",
  "description": "Serena (LSP-based semantic code retrieval/editing) integration for pi, shipped as a peer extension of sages",
  "type": "module",
  "license": "MIT",
  "author": "vanpipy@gmail.com",
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vanpipy/sages.git",
    "directory": "pi-serena"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "serena",
    "mcp",
    "model-context-protocol",
    "lsp",
    "sages",
    "agent"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "src",
    "templates",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.5",
    "@types/node": "^20.10.0",
    "typescript": "^6.0.3"
  }
}
