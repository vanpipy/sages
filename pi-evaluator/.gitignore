# Keep generated code for inspection
evaluations/*/codes/

# Ignore sessions and report outputs
evaluations/*/sessions/
evaluations/*/report/

# Python
__pycache__/
*.pyc

# Node modules (too large)
evaluations/*/codes/*/node_modules/

# Sages orchestrator state (the active 4-tool orchestrator writes
# goal/dag/audit files into this directory).
evaluations/*/codes/.pi/orchestrator/