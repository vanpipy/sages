{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "declaration": false,
    "outDir": "dist",
    "rootDir": ".",
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node", "bun-types"]
  },
  "include": [
    "src/**/*.ts",
    "extensions/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
