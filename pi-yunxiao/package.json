{
  "name": "@sages/pi-yunxiao",
  "version": "0.1.0",
  "description": "Yunxiao (Alibaba Cloud DevOps) MCP integration for pi - 53 official tools via HTTP sidecar",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test test/*.test.ts test/integration/*.test.ts",
    "test:smoke": "bash test/smoke.sh"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "yunxiao",
    "alibaba-cloud",
