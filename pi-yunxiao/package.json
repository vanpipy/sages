      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.5",
    "@types/node": "^20.10.0",
    "bun-types": "^1.1.0",
    "typebox": "^1.1.34",
    "typescript": "^6.0.3"
  },
  "author": "leroy",
  "homepage": "https://codeup.aliyun.com"
}
