{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["bin/**/*", "plugin/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}